{
  "project": {
    "name": "crypto-alpha",
    "data_dir": "data",
    "artifacts_dir": "artifacts",
    "random_seed": 42
  },
  "data": {
    "exchange": "binance",
    "tip_exchange": "gate",
    "exchange_fallbacks": [
      "gate",
      "bitget",
      "mexc"
    ],
    "rest_timeout_ms": 8000,
    "symbols": [
      "BTC/USDT",
      "ETH/USDT"
    ],
    "timeframe": "30m",
    "aux_timeframes": [
      "2h",
      "4h",
      "1d"
    ],
    "since": "2015-09-14T00:00:00Z",
    "use_synthetic": false,
    "synthetic_bars": 40000,
    "allow_synthetic_fallback": false,
    "cache": true,
    "incremental_update": false,
    "refresh_before_decide": false,
    "require_fresh_for_decide": true,
    "max_closed_bar_lag": 4,
    "fetch_derivatives": true,
    "fetch_liquidations": false,
    "liquidations": {
      "store_dir": "liquidations",
      "auto_attach": true,
      "fetch_on_tip": true,
      "exchanges": [
        "gate"
      ],
      "merge_all_exchanges": false
    },
    "fetch_derivatives_on_tip": false
  },
  "news": {
    "use_synthetic": false,
    "use_history": false,
    "output_dir": "data/news",
    "history": {
      "raw_dir": "data/news_raw",
      "start": "2021-01-01T00:00:00Z",
      "end": null,
      "providers": [
        "cryptocompare",
        "gdelt"
      ],
      "window_days": 7,
      "rate_limit_sec": 5.0,
      "max_windows": 400,
      "max_pages": 400,
      "gdelt_query": "(bitcoin OR ethereum)",
      "synthetic_per_day": 8
    },
    "bucket": "30m",
    "top_k": 3,
    "buffer_minutes": 5,
    "dedup_window_hours": 48,
    "auto_build_panel": true,
    "require_panel": false,
    "as_feature": false,
    "feature_ttl_hours": 24,
    "feature_halflife_hours": 6,
    "feature_ema_span": 24,
    "min_coverage_warn": 0.05,
    "require_min_coverage": false,
    "tier_weights": {
      "1": 1.0,
      "2": 0.7,
      "3": 0.4,
      "4": 0.15
    },
    "sentiment": {
      "backend": "lexicon",
      "model_name": null,
      "label_map": null,
      "device": "auto",
      "batch_size": 32,
      "max_length": 128,
      "cache": true,
      "en_backend": "cryptobert",
      "en_model_name": null,
      "zh_backend": "chinese",
      "zh_model_name": null,
      "zh_label_map": null,
      "fusion": "route",
      "fusion_weights": {
        "en": 0.5,
        "zh": 0.5
      }
    },
    "sources": [
      {
        "name": "SEC",
        "type": "rss",
        "tier": 1,
        "url": "https://www.sec.gov/news/pressreleases.rss"
      },
      {
        "name": "CoinDesk",
        "type": "rss",
        "tier": 2,
        "url": "https://www.coindesk.com/arc/outboundfeeds/rss/"
      },
      {
        "name": "Cointelegraph",
        "type": "rss",
        "tier": 3,
        "url": "https://cointelegraph.com/rss"
      },
      {
        "name": "CryptoCompare",
        "type": "cryptocompare",
        "tier": 2,
        "url": "https://min-api.cryptocompare.com/data/v2/news/?lang=EN",
        "api_key_env": "CRYPTOCOMPARE_KEY"
      },
      {
        "name": "CryptoPanic",
        "type": "cryptopanic",
        "tier": 2,
        "url": "https://cryptopanic.com/api/v1/posts/",
        "api_key_env": "CRYPTOPANIC_KEY"
      },
      {
        "name": "GDELT",
        "type": "gdelt",
        "tier": 2
      }
    ]
  },
  "features": {
    "frac_diff_d": 0.4,
    "frac_diff_thres": 0.0001,
    "windows": [
      14,
      28,
      48,
      56,
      112
    ],
    "vol_window": 100,
    "mtf_enabled": true,
    "mtf_lookbacks": [
      1,
      3,
      7
    ],
    "mtf_rsi_window": 14,
    "mtf_vol_window": 14,
    "mtf_include_confluence": true
  },
  "labeling": {
    "barrier_vol": "atr",
    "pt_sl": [
      1.5,
      1.5
    ],
    "vertical_barrier_bars": 48,
    "min_ret": 0.0,
    "primary_signal": "momentum",
    "primary_lookback": 48,
    "min_cusum_events": 50,
    "cusum_min_periods": 100,
    "serve_require_cusum": true
  },
  "validation": {
    "n_splits": 6,
    "n_test_groups": 2,
    "embargo_pct": 0.01,
    "dsr_n_trials": 50,
    "log_experiments": true,
    "walkforward": {
      "enabled_in_run_all": false,
      "require_in_run_all": false,
      "train_start": "2020-01-01T00:00:00Z",
      "test_start": "2024-09-14T00:00:00Z",
      "test_end": "2026-07-18T00:00:00Z",
      "embargo_bars": 0,
      "recompute_sample_weight_on_split": false,
      "min_train_events": 200,
      "min_test_events": 50,
      "initial_capital": 10000.0
    }
  },
  "experts": {
    "enabled": [
      "gbdt",
      "deep_ts"
    ],
    "gbdt": {
      "n_estimators": 400,
      "learning_rate": 0.03,
      "num_leaves": 31,
      "max_depth": -1,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "min_child_samples": 50
    },
    "deep_ts": {
      "lookback": 128,
      "d_model": 64,
      "n_heads": 4,
      "n_layers": 2,
      "patch_len": 8,
      "dropout": 0.1,
      "epochs": 15,
      "batch_size": 256,
      "lr": 0.001,
      "device": "auto",
      "val_frac": 0.15,
      "early_stop_patience": 3,
      "oof_include_post_cutoff": false
    },
    "tsfm": {
      "backend": "chronos",
      "model_name": "amazon/chronos-bolt-base",
      "context_length": 512,
      "horizon": 48,
      "head": "logistic",
      "covariate_cols": "auto"
    },
    "llm": {
      "model_name": "Qwen/Qwen2.5-32B-Instruct",
      "load_in_4bit": true,
      "adapter_path": "artifacts/qwen_qlora_adapter",
      "lora_r": 16,
      "lora_alpha": 32,
      "lora_dropout": 0.05,
      "lora_target_modules": [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj",
        "gate_proj",
        "up_proj",
        "down_proj"
      ],
      "epochs": 2,
      "per_device_batch_size": 4,
      "grad_accum": 8,
      "lr": 0.0001,
      "warmup_ratio": 0.03,
      "weight_decay": 0.0,
      "max_seq_len": 1024,
      "val_frac": 0.15,
      "gradient_checkpointing": true,
      "bf16": true,
      "logging_steps": 20,
      "save_steps": 200,
      "use_sample_weight": true,
      "news_path": null
    }
  },
  "ensemble": {
    "meta_learner": "logistic",
    "C": 1.0,
    "min_expert_auc": 0.5,
    "exclude_pseudo_oof_from_meta": true
  },
  "calibration": {
    "method": "auto",
    "conformal_alpha": 0.1,
    "calib_splits": 5,
    "conformal_frac": 0.3,
    "conformal_min_margin": 0.05,
    "pass_rate_inflate_max": 1.5,
    "min_unique_levels": 20
  },
  "backtest": {
    "fee_bps": 5.0,
    "slippage_bps": 2.0,
    "slippage_vol_scale": true,
    "slippage_vol_mult_cap": 3.0,
    "funding_bps_per_bar": 0.0,
    "prob_threshold": 0.55,
    "prob_threshold_mode": "max_of",
    "prob_quantile": 0.98,
    "target_trade_rate": null,
    "raise_thr_on_inflate": true,
    "inflate_raise_quantile": 0.99,
    "portfolio_mode": true,
    "min_position_pct": 0.01
  },
  "serve": {
    "symbols": null,
    "poll_seconds": 1800,
    "retrain_every_cycles": 48,
    "notify_hold": false,
    "dedupe": true,
    "telegram": {
      "enabled": false,
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "chat_id_env": "TELEGRAM_CHAT_ID"
    }
  },
  "risk": {
    "kelly_fraction": 0.5,
    "max_position_pct": 0.3,
    "max_gross_exposure": 1.0,
    "atr_stop_mult": 1.5,
    "daily_max_drawdown": 0.05,
    "min_kelly_edge": 0.0,
    "roundtrip_cost_frac": null,
    "execution_assumption": "close_fill",
    "env_degradation_hold_score": 50
  }
}